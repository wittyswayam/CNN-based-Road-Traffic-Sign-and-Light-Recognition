{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "json": {
      "()": "src.core.logging.JSONFormatter"
    },
    "default": {
      "fmt": "%(asctime)s %(levelname)s %(name)s: %(message)s",
      "datefmt": "%Y-%m-%dT%H:%M:%S"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout",
      "formatter": "default"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.access": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    },
    "trafficvision": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    }
  },
  "root": {
    "level": "INFO",
    "handlers": ["console"]
  }
}
